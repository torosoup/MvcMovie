@{
    ViewData["Title"] = "Movie List"; // this is the view tempelate Index() in HelloWorldController.cs uses. Index.cshtml is the default view, as view tempelate was not specified. Title property for ViewData. A view tempelate should only work with the data that's provided to it by the controller. No buisness logic.
}

<h2>My Movie List</h2>

<ul>
    @for (int i = 0; i < (int)ViewData["NumTimes"]!; i++)
    {
        <li>@ViewData["Message"]</li>
    }
</ul>
